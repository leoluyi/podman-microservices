# ============================================================================
# 容器鏡像配置
# ============================================================================
# 用途：集中管理所有服務的容器鏡像
# 注意：修改後需要重新部署 Quadlet 配置

# SSL Termination Proxy
SSL_PROXY_IMAGE=localhost/ssl-proxy:latest

# Frontend
FRONTEND_IMAGE=localhost/frontend:latest
# 或使用 Nginx（快速測試）
# FRONTEND_IMAGE=docker.io/library/nginx:alpine

# BFF Gateway
BFF_IMAGE=localhost/bff:latest
# 或使用 Nginx（快速測試）
# BFF_IMAGE=docker.io/library/nginx:alpine

# Database
POSTGRES_IMAGE=docker.io/library/postgres:16-alpine

# Auth Service
API_AUTH_IMAGE=localhost/api-auth:latest

# Backend APIs
API_USER_IMAGE=localhost/api-user:latest
API_ORDER_IMAGE=localhost/api-order:latest
API_PRODUCT_IMAGE=localhost/api-product:latest

# ============================================================================
# 建置指令參考
# ============================================================================
# podman build -f dockerfiles/ssl-proxy/Dockerfile -t localhost/ssl-proxy:latest .
# cd dockerfiles/frontend && podman build -t localhost/frontend:latest .
# cd dockerfiles/bff && podman build -t localhost/bff:latest .
# cd dockerfiles/api-user && podman build -t localhost/api-user:latest .
# cd dockerfiles/api-order && podman build -t localhost/api-order:latest .
# cd dockerfiles/api-product && podman build -t localhost/api-product:latest .

# ============================================================================
# 推送到私有 Registry（可選）
# ============================================================================
# REGISTRY=registry.example.com
# podman tag localhost/api-user:latest $REGISTRY/api-user:latest
# podman push $REGISTRY/api-user:latest
