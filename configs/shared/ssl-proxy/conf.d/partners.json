{
  "partners": {
    "partner-company-a": {
      "secret_env": "JWT_SECRET_PARTNER_A",
      "name": "Company A Corp",
      "permissions": {
        "orders": {
          "endpoints": [
            {"pattern": "/health",                "methods": ["GET"]},
            {"pattern": "/orders/stats",          "methods": ["GET"]},
            {"pattern": "/orders",                "methods": ["GET", "POST"]},
            {"pattern": "^/orders/\\d+$",         "methods": ["GET", "DELETE"], "regex": true},
            {"pattern": "^/orders/\\d+/status$",  "methods": ["PATCH"],        "regex": true}
          ]
        },
        "products": {
          "endpoints": [
            {"pattern": "/health", "methods": ["GET"]},
            {"pattern": "/",       "methods": ["GET"]}
          ]
        },
        "users": {
          "endpoints": [
            {"pattern": "/health", "methods": ["GET"]},
            {"pattern": "/",       "methods": ["GET"]}
          ]
        }
      }
    },
    "partner-company-b": {
      "secret_env": "JWT_SECRET_PARTNER_B",
      "name": "Company B Ltd",
      "permissions": {
        "orders": {
          "endpoints": [
            {"pattern": "/health",         "methods": ["GET"]},
            {"pattern": "/orders/stats",   "methods": ["GET"]},
            {"pattern": "/orders",         "methods": ["GET", "POST"]},
            {"pattern": "^/orders/\\d+$",  "methods": ["GET"], "regex": true}
          ]
        }
      }
    },
    "partner-company-c": {
      "secret_env": "JWT_SECRET_PARTNER_C",
      "name": "Company C Inc",
      "permissions": {
        "orders": {
          "endpoints": [
            {"pattern": "/health",         "methods": ["GET"]},
            {"pattern": "/orders/stats",   "methods": ["GET"]},
            {"pattern": "/orders",         "methods": ["GET"]},
            {"pattern": "^/orders/\\d+$",  "methods": ["GET"], "regex": true}
          ]
        },
        "products": {
          "endpoints": [
            {"pattern": "/health", "methods": ["GET"]},
            {"pattern": "/",       "methods": ["GET"]}
          ]
        }
      }
    }
  }
}
